@model E_com.Models.Coupon
@{
    ViewData["Title"] = "Create Coupon";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3 border-0">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" class="btn btn-sm btn-light rounded-circle me-3"><i class="fa fa-arrow-left"></i></a>
                        <h4 class="mb-0 fw-bold text-dark">Create Coupon</h4>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CouponCode" class="form-label fw-semibold">Coupon Code</label>
                            <input asp-for="CouponCode" class="form-control text-uppercase" placeholder="e.g. SAVE20, SUMMER50" />
                            <span asp-validation-for="CouponCode" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiscountPercentage" class="form-label fw-semibold">Discount Percentage (%)</label>
                            <input asp-for="DiscountPercentage" class="form-control" type="number" step="0.01" min="0" max="100" placeholder="e.g. 20.00" />
                            <span asp-validation-for="DiscountPercentage" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ExpiryDate" class="form-label fw-semibold">Expiry Date</label>
                            <input asp-for="ExpiryDate" class="form-control" type="date" value="@DateTime.UtcNow.AddDays(7).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-semibold d-block">Status</label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="Status" class="form-check-input" type="checkbox" role="switch" checked>
                                <label class="form-check-label text-muted" asp-for="Status">Active (Accepts at checkout)</label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 py-2.5 rounded-3 fw-bold bg-gradient shadow-sm">Save Coupon</button>
                            <a asp-action="Index" class="btn btn-light px-4 py-2.5 rounded-3 fw-semibold">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
