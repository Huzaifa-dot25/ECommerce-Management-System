@model E_com.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Premium E-Shop";
}

<!-- ─── HERO ─────────────────────────────────────────────── -->
<section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content fade-in-up">
        <span class="hero-eyebrow">New Season — 2026 Collection</span>
        <h1 class="hero-title">Elevate<br>Your Style</h1>
        <p class="hero-subtitle">
            Discover our curated selection of premium products,
            crafted for those who appreciate quality.
        </p>
        <div class="hero-cta">
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary btn-lg px-5 delay-1">
                Shop Now
            </a>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-primary btn-lg px-5 delay-2">
                View Lookbook
            </a>
        </div>
    </div>
</section>

<!-- ─── TRUST STRIP ───────────────────────────────────────── -->
<div class="container py-5">
    <div class="row g-3 text-center mb-5">
        <div class="col-6 col-md-3">
            <div class="d-flex flex-column align-items-center gap-2 py-3">
                <i class="fa-solid fa-truck-fast fa-lg" style="color:var(--clr-gold);"></i>
                <span style="font-size:.75rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--clr-mid);">Free Shipping</span>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="d-flex flex-column align-items-center gap-2 py-3">
                <i class="fa-solid fa-rotate-left fa-lg" style="color:var(--clr-gold);"></i>
                <span style="font-size:.75rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--clr-mid);">Easy Returns</span>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="d-flex flex-column align-items-center gap-2 py-3">
                <i class="fa-solid fa-shield-halved fa-lg" style="color:var(--clr-gold);"></i>
                <span style="font-size:.75rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--clr-mid);">Secure Payment</span>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="d-flex flex-column align-items-center gap-2 py-3">
                <i class="fa-solid fa-headset fa-lg" style="color:var(--clr-gold);"></i>
                <span style="font-size:.75rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--clr-mid);">24/7 Support</span>
            </div>
        </div>
    </div>

    <!-- ─── CATEGORIES ──────────────────────────────────────── -->
    <section class="mb-6 pb-2">
        <div class="section-header">
            <div>
                <span class="section-label">Browse By</span>
                <h2 class="section-title">Curated Collections</h2>
            </div>
            <a asp-controller="Shop" asp-action="Index" class="view-all">
                View All <i class="fa fa-arrow-right"></i>
            </a>
        </div>

        @if (!Model.Categories.Any())
        {
            <div class="empty-state">
                <i class="fa fa-folder-open"></i>
                <p>No collections available yet.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var category in Model.Categories)
                {
                    <div class="col-6 col-md-3">
                        <a class="cat-card" asp-controller="Shop" asp-action="Index" asp-route-categoryId="@category.Id">
                            <div class="cat-card__img-wrap">
                                <img class="cat-card__img"
                                     src="@(string.IsNullOrEmpty(category.ImagePath) ? "https://placehold.co/200x200?text=+" : category.ImagePath)"
                                     alt="@category.Name"
                                     onerror="this.src='https://placehold.co/200x200?text=+'" />
                            </div>
                            <p class="cat-card__name">@category.Name</p>
                            <span class="cat-card__count">@category.Products.Count() pieces</span>
                        </a>
                    </div>
                }
            </div>
        }
    </section>

    <!-- ─── FEATURED PRODUCTS ───────────────────────────────── -->
    <section class="mb-5">
        <div class="section-header">
            <div>
                <span class="section-label">Just In</span>
                <h2 class="section-title">New Arrivals</h2>
            </div>
            <a asp-controller="Shop" asp-action="Index" class="view-all">
                Discover All <i class="fa fa-arrow-right"></i>
            </a>
        </div>

        @if (!Model.FeaturedProducts.Any())
        {
            <div class="empty-state">
                <i class="fa fa-box-open"></i>
                <p>Check back later for new arrivals.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var product in Model.FeaturedProducts)
                {
                    var primaryImage = product.ProductImages.FirstOrDefault(i => i.IsPrimary)
                                    ?? product.ProductImages.FirstOrDefault();
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="product-card">
                            <div class="product-card__img-wrap">
                                <img class="product-card__img"
                                     src="@(primaryImage != null ? primaryImage.ImagePath : "/images/placeholder-product.png")"
                                     alt="@product.Name"
                                     onerror="this.src='https://placehold.co/400x400?text=Product'" />

                                @if (product.Discount > 0)
                                {
                                    <span class="product-card__badge">-@product.Discount.ToString("F0")%</span>
                                }

                                <a class="product-card__quick" asp-controller="Shop" asp-action="Details" asp-route-id="@product.Id">
                                    Quick View &nbsp;<i class="fa fa-arrow-right"></i>
                                </a>
                            </div>
                            <div class="product-card__body">
                                <p class="product-card__brand">@product.Brand</p>
                                <a class="product-card__name" asp-controller="Shop" asp-action="Details" asp-route-id="@product.Id">
                                    @product.Name
                                </a>
                                <div class="product-card__footer">
                                    <div>
                                        <span class="product-card__price">$@product.DiscountedPrice.ToString("F2")</span>
                                        @if (product.Discount > 0)
                                        {
                                            <span class="product-card__original">$@product.Price.ToString("F2")</span>
                                        }
                                    </div>
                                    <a class="product-card__arrow" asp-controller="Shop" asp-action="Details" asp-route-id="@product.Id" title="View Details">
                                        <i class="fa fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- ─── BANNER CTA ──────────────────────────────────────── -->
    <section class="mb-5">
        <div class="rounded" style="background:var(--clr-black); padding: 4rem 3rem; position:relative; overflow:hidden;">
            <div style="position:absolute;top:-40px;right:-40px;width:300px;height:300px;border-radius:50%;background:rgba(184,150,62,.08);"></div>
            <div style="position:absolute;bottom:-60px;left:-20px;width:200px;height:200px;border-radius:50%;background:rgba(184,150,62,.05);"></div>
            <div class="row align-items-center position-relative">
                <div class="col-lg-8">
                    <span style="font-size:.72rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--clr-gold);">Limited Time Offer</span>
                    <h2 style="font-family:var(--ff-display);color:#fff;font-size:clamp(1.6rem,3vw,2.4rem);margin-top:.5rem;margin-bottom:.75rem;">
                        Up to 40% Off &mdash; Selected Items
                    </h2>
                    <p style="color:rgba(255,255,255,.5);font-size:.9rem;margin-bottom:0;">
                        Don't miss our end-of-season sale. Premium quality at exceptional value.
                    </p>
                </div>
                <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
                    <a asp-controller="Shop" asp-action="Index" asp-route-sortBy="discount" class="btn btn-gold btn-lg px-5">
                        Shop Sale
                    </a>
                </div>
            </div>
        </div>
    </section>

</div><!-- /container -->
