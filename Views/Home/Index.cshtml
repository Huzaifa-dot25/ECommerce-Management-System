@model E_com.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Premium E-Shop";
}

<!-- Hero Section -->
<section class="hero-section text-center mb-5 d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="hero-overlay"></div>
    <div class="position-relative z-index-1 p-5">
        <h1 class="display-3 mb-4 animate__animated animate__fadeInDown" style="color: var(--primary-color);">Elevate Your Style</h1>
        <p class="lead mb-5 animate__animated animate__fadeInUp" style="color: #555; max-width: 600px; margin: 0 auto;">
            Discover our curated collection of premium products, designed for the modern connoisseur.
        </p>
        <div class="animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary btn-lg px-5 py-3 shadow-none">
                Explore Collection
            </a>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="mb-5 pt-4">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2">
        <h3 class="mb-0">Curated Collections</h3>
        <a asp-controller="Shop" asp-action="Index" class="text-dark text-decoration-none text-uppercase tracking-wider" style="font-size: 0.8rem; font-weight: 500;">
            View All <i class="fa fa-arrow-right ms-1"></i>
        </a>
    </div>
    
    <div class="row g-4 mt-2">
        @if (!Model.Categories.Any())
        {
            <div class="col-12 text-center text-muted py-5">
                <p>No collections available at the moment.</p>
            </div>
        }
        else
        {
            foreach (var category in Model.Categories)
            {
                <div class="col-6 col-md-3">
                    <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@category.Id" class="text-decoration-none group">
                        <div class="card text-center card-hover p-4 h-100 d-flex flex-column align-items-center justify-content-center">
                            <div class="mb-4 overflow-hidden rounded-circle" style="width: 100px; height: 100px; border: 1px solid var(--border-color); padding: 5px;">
                                <img src="@(string.IsNullOrEmpty(category.ImagePath) ? "https://placehold.co/200x200?text=+" : category.ImagePath)" 
                                     class="w-100 h-100 object-fit-cover rounded-circle transition-transform" 
                                     alt="@category.Name"
                                     style="transition: transform 0.5s ease;"
                                     onmouseover="this.style.transform='scale(1.1)'"
                                     onmouseout="this.style.transform='scale(1)'"
                                     onerror="this.src='https://placehold.co/200x200?text=+'" />
                            </div>
                            <h6 class="mb-1 text-dark text-uppercase tracking-wider" style="font-size: 0.9rem;">@category.Name</h6>
                            <span class="text-muted" style="font-size: 0.75rem;">@category.Products.Count() Pieces</span>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</section>

<!-- Featured Products Section -->
<section class="mb-5 pt-4">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2">
        <h3 class="mb-0">New Arrivals</h3>
        <a asp-controller="Shop" asp-action="Index" class="text-dark text-decoration-none text-uppercase tracking-wider" style="font-size: 0.8rem; font-weight: 500;">
            Discover <i class="fa fa-arrow-right ms-1"></i>
        </a>
    </div>

    <div class="row g-4 mt-2">
        @if (!Model.FeaturedProducts.Any())
        {
            <div class="col-12 text-center text-muted py-5">
                <p class="mb-0">Check back later for new arrivals.</p>
            </div>
        }
        else
        {
            foreach (var product in Model.FeaturedProducts)
            {
                var primaryImage = product.ProductImages.FirstOrDefault(i => i.IsPrimary) ?? product.ProductImages.FirstOrDefault();
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 card-hover d-flex flex-column border-0" style="background: transparent;">
                        <!-- Product Image & Badges -->
                        <div class="position-relative overflow-hidden bg-white border" style="padding-top: 120%;">
                            <a asp-controller="Shop" asp-action="Details" asp-route-id="@product.Id">
                                <img src="@(primaryImage != null ? primaryImage.ImagePath : "/images/placeholder-product.png")" 
                                     class="position-absolute top-0 start-0 w-100 h-100 object-fit-cover transition-transform" 
                                     alt="@product.Name"
                                     style="transition: transform 0.6s ease;"
                                     onmouseover="this.style.transform='scale(1.05)'"
                                     onmouseout="this.style.transform='scale(1)'"
                                     onerror="this.src='https://placehold.co/400x500?text=Product'" />
                            </a>
                            
                            @if (product.Discount > 0)
                            {
                                <span class="position-absolute top-0 end-0 m-3 badge bg-dark px-2 py-1" style="font-size: 0.7rem;">
                                    -@product.Discount.ToString("F0")%
                                </span>
                            }
                        </div>

                        <!-- Product details -->
                        <div class="card-body p-3 px-0 d-flex flex-column">
                            <span class="text-muted text-uppercase tracking-wider mb-1" style="font-size: 0.7rem;">@product.Brand</span>
                            <h5 class="card-title mb-2 text-truncate-2" style="font-size: 1rem; line-height: 1.4;">
                                <a asp-controller="Shop" asp-action="Details" asp-route-id="@product.Id" class="text-dark text-decoration-none">
                                    @product.Name
                                </a>
                            </h5>
                            
                            <div class="mt-auto pt-2">
                                @if (product.Discount > 0)
                                {
                                    <span class="fw-bold" style="color: var(--primary-color);">$@product.DiscountedPrice.ToString("F2")</span>
                                    <span class="text-decoration-line-through text-muted ms-2" style="font-size: 0.85rem;">$@product.Price.ToString("F2")</span>
                                }
                                else
                                {
                                    <span class="fw-bold" style="color: var(--primary-color);">$@product.Price.ToString("F2")</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</section>
