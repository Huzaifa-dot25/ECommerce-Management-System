@using Microsoft.AspNetCore.Identity
@using E_com.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-auto align-items-center gap-1">
    @if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        <li class="nav-item">
            <a class="nav-icon-btn" asp-controller="Wishlist" asp-action="Index" title="Wishlist">
                <i class="fa-regular fa-heart"></i>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-icon-btn" asp-controller="Cart" asp-action="Index" title="Cart">
                <i class="fa-solid fa-bag-shopping"></i>
                <span class="badge bg-dark" id="cart-badge" style="display:none;">0</span>
            </a>
        </li>
        <li class="nav-item dropdown ms-1">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 py-0"
               href="#" id="userDropdown" role="button"
               data-bs-toggle="dropdown" aria-expanded="false"
               style="color:var(--clr-dark)!important;">
                <img src="@(string.IsNullOrEmpty(user?.ProfilePicture)
                    ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(user?.FullName ?? "U")}&background=111111&color=fff&size=64"
                    : user.ProfilePicture)"
                     style="width:34px;height:34px;border-radius:50%;object-fit:cover;border:2px solid var(--clr-border);"
                     alt="Avatar" />
                <span style="font-size:.8rem;font-weight:600;letter-spacing:.04em;">@user?.FullName</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                <li>
                    <span class="dropdown-header" style="font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:var(--clr-muted);">
                        My Account
                    </span>
                </li>
                <li>
                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                        <i class="fa fa-user-circle me-2 text-muted"></i>Profile
                    </a>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li>
                        <a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">
                            <i class="fa fa-gauge me-2 text-muted"></i>Admin Panel
                        </a>
                    </li>
                }
                else
                {
                    <li>
                        <a class="dropdown-item" asp-controller="Orders" asp-action="MyOrders">
                            <i class="fa fa-box me-2 text-muted"></i>My Orders
                        </a>
                    </li>
                }
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="w-100">
                        <button type="submit" class="dropdown-item text-dark border-0 bg-transparent w-100 text-start">
                            <i class="fa-solid fa-right-from-bracket me-2 text-muted"></i>Sign Out
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
        </li>
        <li class="nav-item ms-1">
            <a class="btn btn-primary px-4" asp-controller="Account" asp-action="Login">
                Sign In
            </a>
        </li>
    }
</ul>
