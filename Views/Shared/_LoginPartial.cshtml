@using Microsoft.AspNetCore.Identity
@using E_com.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-auto align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        <li class="nav-item me-3">
            <a class="nav-link position-relative text-dark px-2" asp-controller="Wishlist" asp-action="Index" title="Wishlist">
                <i class="fa-regular fa-heart fs-5"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="wishlist-badge">0</span>
            </a>
        </li>
        <li class="nav-item me-3">
            <a class="nav-link position-relative text-dark px-2" asp-controller="Cart" asp-action="Index" title="Shopping Cart">
                <i class="fa-solid fa-cart-shopping fs-5"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary" id="cart-badge">0</span>
            </a>
        </li>
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle text-dark fw-semibold d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <img src="@(string.IsNullOrEmpty(user?.ProfilePicture) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(user?.FullName ?? "User")}&background=0D6EFD&color=fff" : user.ProfilePicture)" 
                     class="rounded-circle me-2" 
                     style="width: 32px; height: 32px; object-fit: cover;" 
                     alt="Avatar" />
                @user?.FullName
            </a>
            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3" aria-labelledby="userDropdown">
                <li><a class="dropdown-header text-muted">Manage Account</a></li>
                <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile"><i class="fa fa-user-circle me-2 text-muted"></i> My Profile</a></li>
                @if (User.IsInRole("Admin"))
                {
                    <li><a class="dropdown-item py-2 text-danger" asp-controller="Admin" asp-action="Dashboard"><i class="fa fa-dashboard me-2"></i> Admin Panel</a></li>
                }
                else
                {
                    <li><a class="dropdown-item py-2" asp-controller="Orders" asp-action="MyOrders"><i class="fa fa-shopping-bag me-2 text-muted"></i> My Orders</a></li>
                }
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="d-inline w-100">
                        <button type="submit" class="dropdown-item py-2 text-dark border-0 bg-transparent w-100 text-start">
                            <i class="fa-solid fa-right-from-bracket me-2 text-muted"></i> Log Out
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark fw-medium" asp-controller="Account" asp-action="Register"><i class="fa fa-user-plus me-1"></i> Register</a>
        </li>
        <li class="nav-item ms-2">
            <a class="btn btn-primary px-3 py-1.5 rounded-pill fw-semibold bg-gradient shadow-sm" asp-controller="Account" asp-action="Login"><i class="fa fa-sign-in-alt me-1"></i> Login</a>
        </li>
    }
</ul>
