<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_com.styles.css" asp-append-version="true" />
</head>
<body>

<!-- ─── HEADER / NAVBAR ──────────────────────────────────── -->
<header class="site-header">
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                E<span>&#8209;</span>SHOP
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarContent" aria-controls="navbarContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse" id="navbarContent">
                <!-- Left nav links -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Shop" asp-action="Index">Collection</a>
                    </li>
                </ul>

                <!-- Right: account / cart icons -->
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
</header>

<!-- ─── MAIN CONTENT ─────────────────────────────────────── -->
<main role="main" class="pb-5 pt-4">
    @RenderBody()
</main>

<!-- ─── TOAST NOTIFICATIONS ──────────────────────────────── -->
<div class="toast-container position-fixed bottom-0 end-0 p-4" style="z-index:1100;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successToast" class="toast align-items-center text-white bg-dark border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fa-solid fa-check-circle me-2" style="color:var(--clr-gold);"></i>
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div id="errorToast" class="toast align-items-center text-white bg-dark border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fa-solid fa-circle-exclamation me-2 text-danger"></i>
                    @TempData["ErrorMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
</div>

<!-- ─── FOOTER ────────────────────────────────────────────── -->
<footer class="site-footer">
    <div class="container">
        <div class="row g-5">
            <!-- Brand column -->
            <div class="col-lg-4 col-md-6">
                <a class="site-footer__brand" asp-controller="Home" asp-action="Index">E<span>&#8209;</span>SHOP</a>
                <p class="site-footer__tagline">Curated for the modern connoisseur.</p>
                <p style="font-size:.85rem; line-height:1.7; color:rgba(255,255,255,.45);">
                    Premium products, thoughtfully selected and delivered to your door.
                </p>
            </div>

            <!-- Quick links -->
            <div class="col-lg-2 col-md-3 col-6">
                <p class="footer-heading">Shop</p>
                <ul class="footer-nav">
                    <li><a asp-controller="Shop" asp-action="Index">All Products</a></li>
                    <li><a asp-controller="Home" asp-action="Index">New Arrivals</a></li>
                </ul>
            </div>

            <!-- Account links -->
            <div class="col-lg-2 col-md-3 col-6">
                <p class="footer-heading">Account</p>
                <ul class="footer-nav">
                    <li><a asp-controller="Account" asp-action="Login">Login</a></li>
                    <li><a asp-controller="Account" asp-action="Register">Register</a></li>
                    <li><a asp-controller="Account" asp-action="Profile">My Profile</a></li>
                </ul>
            </div>

            <!-- Legal links -->
            <div class="col-lg-2 col-md-3 col-6">
                <p class="footer-heading">Legal</p>
                <ul class="footer-nav">
                    <li><a asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                </ul>
            </div>
        </div>

        <hr class="site-footer__divider" />
        <p class="site-footer__copy text-center mb-0">&copy; 2026 E-Shop &mdash; All rights reserved.</p>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        ['successToast', 'errorToast'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) new bootstrap.Toast(el, { delay: 4500 }).show();
        });
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
