<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin · E-Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* ── Admin shell ─────────────────────────────────────── */
        body { background: #f4f2ef; }

        .admin-shell { display: flex; min-height: 100vh; }

        /* Sidebar */
        .admin-sidebar {
            width: 240px;
            min-width: 240px;
            background: var(--clr-black);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 1030;
            overflow-y: auto;
        }
        .admin-sidebar__brand {
            padding: 22px 24px 18px;
            border-bottom: 1px solid rgba(255,255,255,.07);
        }
        .admin-sidebar__brand a {
            font-family: var(--ff-display);
            font-size: 1.3rem;
            font-weight: 700;
            color: #fff;
            text-decoration: none;
            letter-spacing: .04em;
        }
        .admin-sidebar__brand a span { color: var(--clr-gold); }
        .admin-sidebar__badge {
            display: inline-block;
            font-size: .58rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            background: rgba(184,150,62,.18);
            color: var(--clr-gold-lt);
            border: 1px solid rgba(184,150,62,.25);
            border-radius: 4px;
            padding: 2px 7px;
            margin-top: 4px;
        }
        .admin-nav { padding: 16px 0; flex: 1; }
        .admin-nav__section {
            font-size: .62rem;
            font-weight: 700;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: rgba(255,255,255,.25);
            padding: 18px 24px 8px;
        }
        .admin-nav__link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 24px;
            font-size: .83rem;
            font-weight: 500;
            color: rgba(255,255,255,.55);
            text-decoration: none;
            transition: all .2s;
            border-left: 3px solid transparent;
        }
        .admin-nav__link:hover {
            color: #fff;
            background: rgba(255,255,255,.05);
            border-left-color: rgba(184,150,62,.4);
        }
        .admin-nav__link.active {
            color: #fff;
            background: rgba(255,255,255,.07);
            border-left-color: var(--clr-gold);
        }
        .admin-nav__link i { width: 18px; text-align: center; font-size: .85rem; }
        .admin-sidebar__footer {
            padding: 16px 24px;
            border-top: 1px solid rgba(255,255,255,.07);
        }

        /* Main content area */
        .admin-main {
            margin-left: 240px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Top bar */
        .admin-topbar {
            background: #fff;
            border-bottom: 1px solid var(--clr-border);
            padding: 0 28px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .admin-topbar__title {
            font-family: var(--ff-body);
            font-size: .88rem;
            font-weight: 600;
            color: var(--clr-mid);
            letter-spacing: .02em;
        }
        .admin-topbar__title strong { color: var(--clr-black); font-size: 1rem; }

        /* Content padding */
        .admin-content { padding: 28px; flex: 1; }

        /* Stat cards */
        .stat-card {
            background: #fff;
            border: 1px solid var(--clr-border);
            border-radius: var(--radius-md);
            padding: 22px 24px;
            display: flex;
            align-items: center;
            gap: 18px;
        }
        .stat-card__icon {
            width: 48px; height: 48px;
            border-radius: var(--radius-sm);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }
        .stat-card__label {
            font-size: .72rem;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--clr-muted);
            margin-bottom: 4px;
        }
        .stat-card__value {
            font-size: 1.7rem;
            font-weight: 700;
            color: var(--clr-black);
            line-height: 1;
        }

        /* Admin table */
        .admin-table th {
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--clr-muted);
            border-bottom: 2px solid var(--clr-border) !important;
            padding: 12px 16px;
            background: #faf9f7;
        }
        .admin-table td { padding: 14px 16px; vertical-align: middle; border-bottom: 1px solid #f4f2ef; }
        .admin-table tbody tr:last-child td { border-bottom: 0; }
        .admin-table tbody tr:hover td { background: #faf9f7; }

        /* Page header inside content */
        .admin-page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }
        .admin-page-header h1 {
            font-family: var(--ff-body);
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--clr-black);
            margin: 0;
        }
        .admin-page-header p { font-size: .84rem; color: var(--clr-muted); margin: 3px 0 0; }

        @@media (max-width: 991px) {
            .admin-sidebar { width: 200px; min-width: 200px; }
            .admin-main { margin-left: 200px; }
        }
    </style>
</head>
<body>
<div class="admin-shell">

    <!-- ── SIDEBAR ───────────────────────────────────────────── -->
    <aside class="admin-sidebar">
        <div class="admin-sidebar__brand">
            <a asp-controller="Home" asp-action="Index">E<span>&#8209;</span>SHOP</a>
            <div class="admin-sidebar__badge">Admin Panel</div>
        </div>

        <nav class="admin-nav">
            <p class="admin-nav__section">Overview</p>
            <a class="admin-nav__link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
               asp-controller="Admin" asp-action="Dashboard">
                <i class="fa fa-gauge"></i> Dashboard
            </a>

            <p class="admin-nav__section">Catalog</p>
            <a class="admin-nav__link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"
               asp-controller="Product" asp-action="Index">
                <i class="fa fa-box"></i> Products
            </a>
            <a class="admin-nav__link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
               asp-controller="Category" asp-action="Index">
                <i class="fa fa-tag"></i> Categories
            </a>
            <a class="admin-nav__link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Coupon" ? "active" : "")"
               asp-controller="Coupon" asp-action="Index">
                <i class="fa fa-ticket"></i> Coupons
            </a>

            <p class="admin-nav__section">Store</p>
            <a class="admin-nav__link" asp-controller="Home" asp-action="Index" target="_blank">
                <i class="fa fa-arrow-up-right-from-square"></i> View Store
            </a>
        </nav>

        <div class="admin-sidebar__footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" style="background:none;border:none;padding:0;cursor:pointer;display:flex;align-items:center;gap:10px;color:rgba(255,255,255,.4);font-size:.8rem;font-weight:500;transition:color .2s;"
                        onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.4)'">
                    <i class="fa fa-right-from-bracket"></i> Sign Out
                </button>
            </form>
        </div>
    </aside>

    <!-- ── MAIN ──────────────────────────────────────────────── -->
    <div class="admin-main">

        <!-- Top bar -->
        <div class="admin-topbar">
            <div class="admin-topbar__title">
                <strong>@(ViewData["Title"] ?? "Dashboard")</strong>
            </div>
            <div class="d-flex align-items-center gap-3">
                @if (TempData["SuccessMessage"] != null)
                {
                    <span class="badge rounded-pill px-3 py-2" style="background:#e8f5e9;color:#2d8a4e;font-size:.78rem;">
                        <i class="fa fa-check me-1"></i>@TempData["SuccessMessage"]
                    </span>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <span class="badge rounded-pill px-3 py-2" style="background:#fdecea;color:#c0392b;font-size:.78rem;">
                        <i class="fa fa-exclamation-circle me-1"></i>@TempData["ErrorMessage"]
                    </span>
                }
                <a asp-controller="Account" asp-action="Profile"
                   style="font-size:.82rem;font-weight:600;color:var(--clr-dark);text-decoration:none;">
                    <i class="fa fa-user-circle me-1 text-muted"></i>Admin
                </a>
            </div>
        </div>

        <!-- Page content -->
        <div class="admin-content">
            @RenderBody()
        </div>
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
