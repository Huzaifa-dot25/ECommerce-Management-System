@model E_com.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
    decimal subTotal = Model.Cart!.CartItems.Sum(ci => ci.Product!.DiscountedPrice * ci.Quantity);
}

<div class="container py-5">
    <h2 class="fw-bold text-dark mb-4"><i class="fa-solid fa-cash-register text-primary me-2"></i>Checkout</h2>

    <form asp-action="Index" method="post" id="checkoutForm">
        <div class="row">
            <!-- Shipping Details -->
            <div class="col-lg-7 mb-4">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold text-dark mb-4"><i class="fa fa-truck text-muted me-2"></i>Shipping Address</h5>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="StreetAddress" class="form-label fw-semibold"></label>
                        <input asp-for="StreetAddress" class="form-control" placeholder="123 Main St, Apt 4B" />
                        <span asp-validation-for="StreetAddress" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="City" class="form-label fw-semibold"></label>
                            <input asp-for="City" class="form-control" placeholder="New York" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="State" class="form-label fw-semibold"></label>
                            <input asp-for="State" class="form-control" placeholder="NY" />
                            <span asp-validation-for="State" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PostalCode" class="form-label fw-semibold"></label>
                            <input asp-for="PostalCode" class="form-control" placeholder="10001" />
                            <span asp-validation-for="PostalCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label fw-semibold"></label>
                            <input asp-for="Phone" class="form-control" placeholder="(555) 555-5555" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="fw-bold text-dark mt-4 mb-3"><i class="fa fa-credit-card text-muted me-2"></i>Payment Method</h5>
                    <div class="border rounded-3 p-3 bg-light mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="Cash On Delivery" checked />
                            <label class="form-check-label fw-bold text-dark" asp-for="PaymentMethod">
                                Cash On Delivery (COD)
                            </label>
                            <p class="text-muted small mb-0 mt-1">Pay with cash upon delivery of your items.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Summary & Coupons -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 90px;">
                    <h5 class="fw-bold text-dark mb-4">Your Order</h5>
                    
                    <div class="mb-4" style="max-height: 200px; overflow-y: auto;">
                        @foreach (var item in Model.Cart!.CartItems)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div style="max-width: 75%;">
                                    <span class="fw-bold text-dark">@item.Quantity x</span>
                                    <span class="text-muted ms-1">@item.Product?.Name</span>
                                </div>
                                <span class="fw-semibold text-dark">$@((item.Product!.DiscountedPrice * item.Quantity).ToString("F2"))</span>
                            </div>
                        }
                    </div>

                    <hr class="my-4">

                    <!-- Coupon Code Input -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Discount Coupon</label>
                        <div class="input-group">
                            <input type="text" id="couponCodeInput" asp-for="CouponCode" class="form-control bg-light" placeholder="Enter coupon code" />
                            <button type="button" id="applyCouponBtn" class="btn btn-secondary px-3">Apply</button>
                        </div>
                        <div id="couponMessage" class="small mt-1"></div>
                    </div>

                    <!-- Summary math -->
                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Subtotal:</span>
                        <span>$@subTotal.ToString("F2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-danger d-none" id="discountRow">
                        <span>Discount (<span id="discountPercent">0</span>%):</span>
                        <span>-$<span id="discountAmount">0.00</span></span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Shipping:</span>
                        <span class="text-success fw-bold">FREE</span>
                    </div>
                    
                    <hr class="my-3">
                    
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold text-dark fs-5">Total to Pay:</span>
                        <span class="fs-4 fw-bold text-primary">$<span id="totalAmount">@subTotal.ToString("F2")</span></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold bg-gradient shadow-sm">
                        Place Order
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $("#applyCouponBtn").click(function () {
                var code = $("#couponCodeInput").val().trim();
                var subtotal = @subTotal;
                
                if (code === "") {
                    $("#couponMessage").text("Please enter a coupon code.").removeClass("text-success").addClass("text-danger");
                    return;
                }

                $.ajax({
                    url: '@Url.Action("ValidateCoupon", "Checkout")',
                    type: 'GET',
                    data: { code: code, subtotal: subtotal },
                    success: function (res) {
                        if (res.success) {
                            $("#couponMessage").text("Coupon applied successfully!").removeClass("text-danger").addClass("text-success");
                            $("#discountPercent").text(res.discountPercent);
                            $("#discountAmount").text(res.discountAmount);
                            $("#discountRow").removeClass("d-none");
                            $("#totalAmount").text(res.total);
                        } else {
                            $("#couponMessage").text(res.message).removeClass("text-success").addClass("text-danger");
                            $("#discountRow").addClass("d-none");
                            $("#totalAmount").text(subtotal.toFixed(2));
                        }
                    },
                    error: function () {
                        $("#couponMessage").text("An error occurred. Try again.").removeClass("text-success").addClass("text-danger");
                    }
                });
            });
        });
    </script>
}
