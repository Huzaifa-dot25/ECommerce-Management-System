@model E_com.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
    decimal subTotal = Model.Cart!.CartItems.Sum(ci => ci.Product!.DiscountedPrice * ci.Quantity);
}

<div class="container py-5">

    <div class="mb-5">
        <span class="section-label">Almost There</span>
        <h1 class="section-title">Checkout</h1>
    </div>

    <!-- Steps indicator -->
    <div class="d-flex align-items-center checkout-steps mb-5 gap-2 flex-wrap">
        <div class="checkout-step active">
            <span class="checkout-step__num">1</span>
            <span>Shipping</span>
        </div>
        <div class="step-sep"></div>
        <div class="checkout-step active">
            <span class="checkout-step__num">2</span>
            <span>Payment</span>
        </div>
        <div class="step-sep"></div>
        <div class="checkout-step">
            <span class="checkout-step__num">3</span>
            <span>Confirmation</span>
        </div>
    </div>

    <form asp-action="Index" method="post" id="checkoutForm">
        <div class="row g-4">

            <!-- ── LEFT: Shipping + Payment ──────────────────── -->
            <div class="col-lg-7">

                <!-- Shipping card -->
                <div class="card border-0 p-4 mb-4" style="box-shadow:var(--shadow-sm);">
                    <h6 style="font-size:.72rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--clr-muted);margin-bottom:1.5rem;">
                        <i class="fa fa-location-dot me-2"></i>Shipping Address
                    </h6>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded mb-3 py-2" style="font-size:.85rem;"></div>

                    <div class="mb-3">
                        <label asp-for="StreetAddress" class="form-label"></label>
                        <input asp-for="StreetAddress" class="form-control" placeholder="123 Main St, Apt 4B" />
                        <span asp-validation-for="StreetAddress" class="text-danger" style="font-size:.78rem;"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="City" class="form-label"></label>
                            <input asp-for="City" class="form-control" placeholder="New York" />
                            <span asp-validation-for="City" class="text-danger" style="font-size:.78rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="State" class="form-label"></label>
                            <input asp-for="State" class="form-control" placeholder="NY" />
                            <span asp-validation-for="State" class="text-danger" style="font-size:.78rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PostalCode" class="form-label"></label>
                            <input asp-for="PostalCode" class="form-control" placeholder="10001" />
                            <span asp-validation-for="PostalCode" class="text-danger" style="font-size:.78rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" placeholder="(555) 555-5555" />
                            <span asp-validation-for="Phone" class="text-danger" style="font-size:.78rem;"></span>
                        </div>
                    </div>
                </div>

                <!-- Payment card -->
                <div class="card border-0 p-4" style="box-shadow:var(--shadow-sm);">
                    <h6 style="font-size:.72rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--clr-muted);margin-bottom:1.5rem;">
                        <i class="fa fa-credit-card me-2"></i>Payment Method
                    </h6>
                    <label class="d-flex align-items-start gap-3 p-4 rounded cursor-pointer" style="border:1.5px solid var(--clr-black);background:#faf9f7;cursor:pointer;">
                        <input class="form-check-input mt-1 flex-shrink-0" type="radio" asp-for="PaymentMethod" value="Cash On Delivery" checked />
                        <div>
                            <p class="mb-0 fw-600" style="font-weight:600;font-size:.9rem;">Cash on Delivery</p>
                            <p class="mb-0 text-muted" style="font-size:.8rem;">Pay with cash when your order arrives.</p>
                        </div>
                    </label>
                </div>

            </div>

            <!-- ── RIGHT: Order Summary ───────────────────────── -->
            <div class="col-lg-5">
                <div class="card border-0 p-4" style="box-shadow:var(--shadow-sm);position:sticky;top:86px;">
                    <h6 style="font-size:.72rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--clr-muted);margin-bottom:1.5rem;">Your Order</h6>

                    <div style="max-height:200px;overflow-y:auto;margin-bottom:1rem;">
                        @foreach (var item in Model.Cart!.CartItems)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3" style="font-size:.88rem;">
                                <div style="max-width:74%;">
                                    <span style="font-weight:700;color:var(--clr-black);">@item.Quantity &times;</span>
                                    <span style="color:var(--clr-mid);margin-left:4px;">@item.Product?.Name</span>
                                </div>
                                <span style="font-weight:600;">$@((item.Product!.DiscountedPrice * item.Quantity).ToString("F2"))</span>
                            </div>
                        }
                    </div>

                    <hr style="border-color:var(--clr-border);" />

                    <!-- Coupon -->
                    <div class="mb-3">
                        <label class="form-label">Discount Coupon</label>
                        <div class="input-group">
                            <input type="text" id="couponCodeInput" asp-for="CouponCode" class="form-control" placeholder="Enter code…" style="font-size:.88rem;" />
                            <button type="button" id="applyCouponBtn" class="btn btn-light" style="font-size:.8rem;letter-spacing:.06em;text-transform:uppercase;">Apply</button>
                        </div>
                        <p id="couponMessage" style="font-size:.78rem;margin-top:4px;"></p>
                    </div>

                    <hr style="border-color:var(--clr-border);" />

                    <div class="d-flex justify-content-between mb-2" style="font-size:.88rem;">
                        <span style="color:var(--clr-muted);">Subtotal</span>
                        <span>$@subTotal.ToString("F2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 d-none" id="discountRow" style="font-size:.88rem;">
                        <span style="color:var(--clr-danger);">Discount (<span id="discountPercent">0</span>%)</span>
                        <span style="color:var(--clr-danger);">-$<span id="discountAmount">0.00</span></span>
                    </div>
                    <div class="d-flex justify-content-between mb-3" style="font-size:.88rem;">
                        <span style="color:var(--clr-muted);">Shipping</span>
                        <span style="color:#2d8a4e;font-weight:600;">Free</span>
                    </div>

                    <hr style="border-color:var(--clr-border);margin-bottom:1.25rem;" />

                    <div class="d-flex justify-content-between mb-4">
                        <span style="font-weight:700;">Total</span>
                        <span style="font-weight:700;font-size:1.3rem;color:var(--clr-black);">$<span id="totalAmount">@subTotal.ToString("F2")</span></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="fa fa-check me-2"></i>Place Order
                    </button>
                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $("#applyCouponBtn").click(function () {
                var code = $("#couponCodeInput").val().trim();
                var subtotal = @subTotal;
                if (!code) {
                    $("#couponMessage").text("Please enter a coupon code.").css("color","var(--clr-danger)");
                    return;
                }
                $.ajax({
                    url: '@Url.Action("ValidateCoupon", "Checkout")',
                    type: 'GET',
                    data: { code: code, subtotal: subtotal },
                    success: function (res) {
                        if (res.success) {
                            $("#couponMessage").text("Coupon applied!").css("color","#2d8a4e");
                            $("#discountPercent").text(res.discountPercent);
                            $("#discountAmount").text(res.discountAmount);
                            $("#discountRow").removeClass("d-none");
                            $("#totalAmount").text(res.total);
                        } else {
                            $("#couponMessage").text(res.message).css("color","var(--clr-danger)");
                            $("#discountRow").addClass("d-none");
                            $("#totalAmount").text(subtotal.toFixed(2));
                        }
                    },
                    error: function () {
                        $("#couponMessage").text("An error occurred. Try again.").css("color","var(--clr-danger)");
                    }
                });
            });
        });
    </script>
}
