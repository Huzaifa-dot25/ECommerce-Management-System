@model IEnumerable<E_com.Models.Wishlist>
@{
    ViewData["Title"] = "My Wishlist";
}

<div class="container py-5">
    <h2 class="fw-bold text-dark mb-4"><i class="fa fa-heart text-danger me-2"></i>My Wishlist</h2>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center my-4">
            <div class="mb-4">
                <i class="fa-regular fa-heart fa-4x text-muted opacity-50"></i>
            </div>
            <h4 class="fw-bold text-dark">Your Wishlist is Empty</h4>
            <p class="text-muted mb-4">Keep track of products you love. Click the heart icon on any product page.</p>
            <div>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-primary px-4 py-2.5 rounded-3 fw-bold bg-gradient shadow-sm">
                    <i class="fa fa-shopping-bag me-2"></i>Browse Products
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                var primaryImage = item.Product?.ProductImages?.FirstOrDefault(pi => pi.IsPrimary) ?? item.Product?.ProductImages?.FirstOrDefault();
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden card-hover d-flex flex-column">
                        <div class="position-relative bg-light" style="padding-top: 100%;">
                            <img src="@(primaryImage != null ? primaryImage.ImagePath : "/images/placeholder-product.png")" 
                                 class="position-absolute top-0 start-0 w-100 h-100 object-fit-cover" 
                                 alt="@item.Product?.Name" 
                                 onerror="this.src='https://placehold.co/300x300?text=Product'" />
                            
                            <form asp-action="Remove" method="post" class="position-absolute top-0 end-0 m-2">
                                <input type="hidden" name="wishlistId" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-light rounded-circle shadow-sm border-0 p-2" style="width: 32px; height: 32px; display: inline-flex; justify-content: center; align-items: center;" title="Remove">
                                    <i class="fa-solid fa-trash text-danger small"></i>
                                </button>
                            </form>
                        </div>
                        <div class="card-body p-3.5 d-flex flex-column flex-grow-1">
                            <span class="text-muted small">@item.Product?.Brand</span>
                            <h6 class="fw-bold text-dark mt-1 mb-2 text-truncate-2" style="height: 38px;">
                                <a asp-controller="Shop" asp-action="Details" asp-route-id="@item.ProductId" class="text-dark text-decoration-none">
                                    @item.Product?.Name
                                </a>
                            </h6>

                            <div class="fw-bold text-primary mb-3">
                                @if (item.Product?.Discount > 0)
                                {
                                    <span>$@item.Product.DiscountedPrice.ToString("F2")</span>
                                    <span class="text-decoration-line-through text-muted small ms-1">$@item.Product.Price.ToString("F2")</span>
                                }
                                else
                                {
                                    <span>$@item.Product?.Price.ToString("F2")</span>
                                }
                            </div>

                            <div class="mt-auto">
                                <form asp-action="MoveToCart" method="post">
                                    <input type="hidden" name="wishlistId" value="@item.Id" />
                                    <button type="submit" class="btn btn-primary w-100 rounded-3 btn-sm py-2 fw-semibold bg-gradient" @(item.Product?.StockQuantity <= 0 ? "disabled" : "")>
                                        <i class="fa fa-shopping-cart me-2"></i>Move to Cart
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
