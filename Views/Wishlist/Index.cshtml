@model IEnumerable<E_com.Models.Wishlist>
@{
    ViewData["Title"] = "My Wishlist";
}

<div class="container py-5">

    <div class="mb-5">
        <span class="section-label">Saved Items</span>
        <h1 class="section-title">My Wishlist</h1>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fa-regular fa-heart d-block"></i>
            <h4>Your Wishlist is Empty</h4>
            <p class="mb-4">Save items you love by clicking the heart icon on any product page.</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary px-5">
                Browse Collection
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                var img = item.Product?.ProductImages?.FirstOrDefault(pi => pi.IsPrimary)
                       ?? item.Product?.ProductImages?.FirstOrDefault();
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="product-card">
                        <div class="product-card__img-wrap">
                            <img class="product-card__img"
                                 src="@(img != null ? img.ImagePath : "/images/placeholder-product.png")"
                                 alt="@item.Product?.Name"
                                 onerror="this.src='https://placehold.co/300x300?text=P'" />

                            <!-- Remove button -->
                            <form asp-action="Remove" method="post" style="position:absolute;top:10px;right:10px;">
                                <input type="hidden" name="wishlistId" value="@item.Id" />
                                <button type="submit" title="Remove"
                                        style="width:32px;height:32px;border-radius:50%;border:0;background:rgba(255,255,255,.9);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;box-shadow:var(--shadow-xs);">
                                    <i class="fa fa-times" style="font-size:.75rem;color:var(--clr-danger);"></i>
                                </button>
                            </form>
                        </div>
                        <div class="product-card__body">
                            <p class="product-card__brand">@item.Product?.Brand</p>
                            <a class="product-card__name" asp-controller="Shop" asp-action="Details" asp-route-id="@item.ProductId">
                                @item.Product?.Name
                            </a>
                            <div class="product-card__footer">
                                <div>
                                    <span class="product-card__price">
                                        $@(item.Product?.Discount > 0 ? item.Product.DiscountedPrice.ToString("F2") : item.Product?.Price.ToString("F2"))
                                    </span>
                                    @if (item.Product?.Discount > 0)
                                    {
                                        <span class="product-card__original">$@item.Product.Price.ToString("F2")</span>
                                    }
                                </div>
                                <form asp-action="MoveToCart" method="post">
                                    <input type="hidden" name="wishlistId" value="@item.Id" />
                                    <button type="submit" class="product-card__arrow" title="Move to Cart"
                                            @(item.Product?.StockQuantity <= 0 ? "disabled" : "")>
                                        <i class="fa fa-cart-plus"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
