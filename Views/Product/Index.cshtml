@model IEnumerable<E_com.Models.Product>
@{
    ViewData["Title"] = "Products Management";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Products</h2>
            <p class="text-muted mb-0">Manage catalog products, stock levels, and pricing</p>
        </div>
        <a asp-action="Create" class="btn btn-primary bg-gradient rounded-3 px-4 py-2 fw-semibold">
            <i class="fa fa-plus me-2"></i>Add Product
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase fs-7 text-muted fw-semibold">
                        <tr>
                            <th class="ps-4">Product</th>
                            <th>SKU</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="fa fa-box-open fa-3x mb-3 opacity-50"></i>
                                    <p class="mb-0">No products found. Click 'Add Product' to create one.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var product in Model)
                            {
                                var primaryImage = product.ProductImages.FirstOrDefault(i => i.IsPrimary) ?? product.ProductImages.FirstOrDefault();
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@(primaryImage != null ? primaryImage.ImagePath : "/images/placeholder-product.png")" 
                                                 class="rounded-3 border object-fit-cover me-3" 
                                                 style="width: 50px; height: 50px;" 
                                                 alt="@product.Name"
                                                 onerror="this.src='https://placehold.co/100x100?text=Product'" />
                                            <div>
                                                <h6 class="fw-semibold mb-0 text-dark">@product.Name</h6>
                                                <span class="text-muted small">Brand: @product.Brand</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <code class="text-secondary bg-light px-2 py-1 rounded">@product.SKU</code>
                                    </td>
                                    <td>
                                        <span class="text-dark">@(product.Category?.Name ?? "Uncategorized")</span>
                                    </td>
                                    <td>
                                        @if (product.Discount > 0)
                                        {
                                            <div>
                                                <span class="fw-bold text-primary">$@product.DiscountedPrice.ToString("F2")</span>
                                                <span class="text-decoration-line-through text-muted small ms-1">$@product.Price.ToString("F2")</span>
                                            </div>
                                            <span class="badge bg-danger-subtle text-danger small py-0.5 px-2 rounded-pill">-@product.Discount.ToString("F0")% Off</span>
                                        }
                                        else
                                        {
                                            <span class="fw-bold text-dark">$@product.Price.ToString("F2")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (product.StockQuantity <= 0)
                                        {
                                            <span class="badge bg-danger text-white py-1.5 px-3">Out of Stock</span>
                                        }
                                        else if (product.StockQuantity <= 10)
                                        {
                                            <span class="badge bg-warning text-dark py-1.5 px-3">Low Stock (@product.StockQuantity)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@product.StockQuantity units</span>
                                        }
                                    </td>
                                    <td>
                                        @if (product.Status)
                                        {
                                            <span class="badge bg-success-subtle text-success badge-pill py-1.5 px-3">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger badge-pill py-1.5 px-3">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-inline-flex gap-2">
                                            <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-secondary rounded-2" title="Edit">
                                                <i class="fa fa-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@product.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this product?');" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-2" title="Delete">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
