@model IEnumerable<E_com.Models.Product>
@{
    ViewData["Title"] = "Products";
    Layout = "_AdminLayout";
}

<div class="admin-page-header">
    <div>
        <h1>Products</h1>
        <p>Manage your catalog — add, edit, or remove products.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa fa-plus me-2"></i>Add Product
    </a>
</div>

<div style="background:#fff;border:1px solid var(--clr-border);border-radius:var(--radius-md);overflow:hidden;">
    <table class="table admin-table mb-0">
        <thead>
            <tr>
                <th style="padding-left:22px;">Product</th>
                <th>SKU</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Status</th>
                <th style="text-align:right;padding-right:22px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" style="text-align:center;padding:48px;color:var(--clr-muted);">
                        <i class="fa fa-box-open d-block mb-3" style="font-size:2rem;opacity:.35;"></i>
                        No products yet. <a asp-action="Create" style="color:var(--clr-black);font-weight:600;">Add your first product →</a>
                    </td>
                </tr>
            }
            else
            {
                foreach (var product in Model)
                {
                    var img = product.ProductImages.FirstOrDefault(i => i.IsPrimary) ?? product.ProductImages.FirstOrDefault();
                    <tr>
                        <td style="padding-left:22px;">
                            <div class="d-flex align-items-center gap-3">
                                <img src="@(img != null ? img.ImagePath : "https://placehold.co/48x48?text=P")"
                                     style="width:44px;height:44px;border-radius:var(--radius-sm);object-fit:cover;border:1px solid var(--clr-border);"
                                     onerror="this.src='https://placehold.co/48x48?text=P'" alt="@product.Name" />
                                <div>
                                    <p style="margin:0;font-weight:600;font-size:.88rem;color:var(--clr-black);">@product.Name</p>
                                    <p style="margin:0;font-size:.74rem;color:var(--clr-muted);">@product.Brand</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <code style="font-size:.76rem;background:#f4f2ef;padding:3px 8px;border-radius:4px;color:var(--clr-mid);">@product.SKU</code>
                        </td>
                        <td style="font-size:.84rem;color:var(--clr-mid);">@(product.Category?.Name ?? "—")</td>
                        <td>
                            <span style="font-weight:700;font-size:.9rem;">$@product.DiscountedPrice.ToString("F2")</span>
                            @if (product.Discount > 0)
                            {
                                <span style="font-size:.74rem;color:var(--clr-muted);text-decoration:line-through;margin-left:4px;">$@product.Price.ToString("F2")</span>
                                <span style="display:block;font-size:.68rem;color:#c0392b;font-weight:600;">-@product.Discount.ToString("F0")% OFF</span>
                            }
                        </td>
                        <td>
                            @if (product.StockQuantity <= 0)
                            {
                                <span style="font-size:.72rem;background:#fdecea;color:#c0392b;padding:3px 10px;border-radius:50px;font-weight:600;">Out of Stock</span>
                            }
                            else if (product.StockQuantity <= 10)
                            {
                                <span style="font-size:.72rem;background:#fef3e2;color:#b8963e;padding:3px 10px;border-radius:50px;font-weight:600;">Low (@product.StockQuantity)</span>
                            }
                            else
                            {
                                <span style="font-size:.84rem;color:var(--clr-mid);">@product.StockQuantity units</span>
                            }
                        </td>
                        <td>
                            @if (product.Status)
                            {
                                <span style="font-size:.72rem;background:#e8f5e9;color:#2d8a4e;padding:3px 10px;border-radius:50px;font-weight:600;">Active</span>
                            }
                            else
                            {
                                <span style="font-size:.72rem;background:#f4f2ef;color:var(--clr-muted);padding:3px 10px;border-radius:50px;font-weight:600;">Inactive</span>
                            }
                        </td>
                        <td style="text-align:right;padding-right:22px;">
                            <div class="d-inline-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-light" title="Edit">
                                    <i class="fa fa-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@product.Id" method="post"
                                      onsubmit="return confirm('Delete @Html.Raw(product.Name.Replace("'","\\'")){?} This cannot be undone.');" class="d-inline">
                                    <button type="submit" class="btn btn-sm" style="background:#fdecea;color:#c0392b;border:0;" title="Delete">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
