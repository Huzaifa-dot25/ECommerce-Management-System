@model E_com.Models.Product
@{
    ViewData["Title"] = "Edit Product";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3 border-0">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" class="btn btn-sm btn-light rounded-circle me-3"><i class="fa fa-arrow-left"></i></a>
                        <h4 class="mb-0 fw-bold text-dark">Edit Product</h4>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedDate" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-semibold">Product Name</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SKU" class="form-label fw-semibold">SKU</label>
                                <input asp-for="SKU" class="form-control" />
                                <span asp-validation-for="SKU" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label fw-semibold">Category</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                                    <option value="">-- Select Category --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Brand" class="form-label fw-semibold">Brand</label>
                                <input asp-for="Brand" class="form-control" />
                                <span asp-validation-for="Brand" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Price" class="form-label fw-semibold">Price ($)</label>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Discount" class="form-label fw-semibold">Discount (%)</label>
                                <input asp-for="Discount" class="form-control" type="number" step="0.01" min="0" max="100" />
                                <span asp-validation-for="Discount" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="StockQuantity" class="form-label fw-semibold">Stock Quantity</label>
                                <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-4 align-items-center">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="form-label fw-semibold">Upload More Images</label>
                                <input type="file" name="imageFiles" class="form-control" accept="image/*" multiple />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label fw-semibold d-block">Status</label>
                                <div class="form-check form-switch mt-2">
                                    <input asp-for="Status" class="form-check-input" type="checkbox" role="switch">
                                    <label class="form-check-label text-muted" asp-for="Status">Active (Visible in shop front)</label>
                                </div>
                            </div>
                        </div>

                        <!-- Current Images Display -->
                        @if (Model.ProductImages != null && Model.ProductImages.Any())
                        {
                            <div class="mb-4">
                                <label class="form-label fw-semibold d-block">Current Images</label>
                                <div class="row g-3">
                                    @foreach (var img in Model.ProductImages)
                                    {
                                        <div class="col-6 col-md-3 col-lg-2">
                                            <div class="position-relative border rounded-3 overflow-hidden shadow-sm" style="height: 120px;">
                                                <img src="@img.ImagePath" class="w-100 h-100 object-fit-cover" alt="Product Image" />
                                                
                                                <!-- Badges and Actions -->
                                                @if (img.IsPrimary)
                                                {
                                                    <span class="position-absolute top-0 start-0 m-1 badge bg-primary small">Primary</span>
                                                }
                                                <button type="submit" class="position-absolute top-0 end-0 m-1 btn btn-xs btn-danger p-1 rounded-circle shadow-sm"
                                                        asp-action="DeleteImage" asp-route-imageId="@img.Id" asp-route-productId="@Model.Id" 
                                                        onclick="return confirm('Are you sure you want to delete this image?');"
                                                        title="Delete Image" style="width: 24px; height: 24px; line-height: 12px; font-size: 10px;">
                                                    <i class="fa fa-times"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 py-2.5 rounded-3 fw-bold bg-gradient shadow-sm">Save Changes</button>
                            <a asp-action="Index" class="btn btn-light px-4 py-2.5 rounded-3 fw-semibold">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
