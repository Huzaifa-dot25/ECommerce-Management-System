@model IEnumerable<E_com.Models.Category>
@{
    ViewData["Title"] = "Categories";
    Layout = "_AdminLayout";
}

<div class="admin-page-header">
    <div>
        <h1>Categories</h1>
        <p>Organise your catalog into browsable collections.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa fa-plus me-2"></i>Add Category
    </a>
</div>

<div style="background:#fff;border:1px solid var(--clr-border);border-radius:var(--radius-md);overflow:hidden;">
    <table class="table admin-table mb-0">
        <thead>
            <tr>
                <th style="padding-left:22px;">Category</th>
                <th>Description</th>
                <th>Products</th>
                <th>Status</th>
                <th>Created</th>
                <th style="text-align:right;padding-right:22px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" style="text-align:center;padding:48px;color:var(--clr-muted);">
                        <i class="fa fa-folder-open d-block mb-3" style="font-size:2rem;opacity:.35;"></i>
                        No categories yet. <a asp-action="Create" style="color:var(--clr-black);font-weight:600;">Create your first →</a>
                    </td>
                </tr>
            }
            else
            {
                foreach (var cat in Model)
                {
                    <tr>
                        <td style="padding-left:22px;">
                            <div class="d-flex align-items-center gap-3">
                                <img src="@(string.IsNullOrEmpty(cat.ImagePath) ? "https://placehold.co/44x44?text=C" : cat.ImagePath)"
                                     style="width:44px;height:44px;border-radius:50%;object-fit:cover;border:1px solid var(--clr-border);"
                                     onerror="this.src='https://placehold.co/44x44?text=C'" alt="@cat.Name" />
                                <span style="font-weight:600;font-size:.88rem;color:var(--clr-black);">@cat.Name</span>
                            </div>
                        </td>
                        <td style="font-size:.83rem;color:var(--clr-muted);max-width:280px;">
                            <span style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">@cat.Description</span>
                        </td>
                        <td>
                            <span style="font-size:.83rem;font-weight:600;color:var(--clr-mid);">@cat.Products.Count products</span>
                        </td>
                        <td>
                            @if (cat.Status)
                            {
                                <span style="font-size:.72rem;background:#e8f5e9;color:#2d8a4e;padding:3px 10px;border-radius:50px;font-weight:600;">Active</span>
                            }
                            else
                            {
                                <span style="font-size:.72rem;background:#f4f2ef;color:var(--clr-muted);padding:3px 10px;border-radius:50px;font-weight:600;">Inactive</span>
                            }
                        </td>
                        <td style="font-size:.83rem;color:var(--clr-muted);">@cat.CreatedDate.ToString("MMM dd, yyyy")</td>
                        <td style="text-align:right;padding-right:22px;">
                            <div class="d-inline-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-light" title="Edit">
                                    <i class="fa fa-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@cat.Id" method="post"
                                      onsubmit="return confirm('Delete @Html.Raw(cat.Name.Replace("'","\\'")){?} Products in this category will not be deleted.');"
                                      class="d-inline">
                                    <button type="submit" class="btn btn-sm" style="background:#fdecea;color:#c0392b;border:0;" title="Delete">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
