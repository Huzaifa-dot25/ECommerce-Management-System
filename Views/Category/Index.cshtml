@model IEnumerable<E_com.Models.Category>
@{
    ViewData["Title"] = "Categories Management";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Categories</h2>
            <p class="text-muted mb-0">Manage catalog categories for your store</p>
        </div>
        <a asp-action="Create" class="btn btn-primary bg-gradient rounded-3 px-4 py-2fw-semibold">
            <i class="fa fa-plus me-2"></i>Add Category
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase fs-7 text-muted fw-semibold">
                        <tr>
                            <th class="ps-4">Image</th>
                            <th>Category Name</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Created Date</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fa fa-folder-open fa-3x mb-3 opacity-50"></i>
                                    <p class="mb-0">No categories found. Click 'Add Category' to create one.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var category in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <img src="@(string.IsNullOrEmpty(category.ImagePath) ? "/images/placeholder-category.png" : category.ImagePath)" 
                                             class="rounded-3 object-fit-cover" 
                                             style="width: 50px; height: 50px;" 
                                             alt="@category.Name" 
                                             onerror="this.src='https://placehold.co/100x100?text=Category'"/>
                                    </td>
                                    <td>
                                        <span class="fw-semibold text-dark">@category.Name</span>
                                    </td>
                                    <td>
                                        <p class="mb-0 text-muted text-truncate" style="max-width: 300px;">@category.Description</p>
                                    </td>
                                    <td>
                                        @if (category.Status)
                                        {
                                            <span class="badge bg-success-subtle text-success badge-pill py-1.5 px-3">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger badge-pill py-1.5 px-3">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-muted">
                                        @category.CreatedDate.ToString("MMM dd, yyyy")
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-inline-flex gap-2">
                                            <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary rounded-2" title="Edit">
                                                <i class="fa fa-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@category.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this category? This will affect products linked to it.');" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-2" title="Delete">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
