@model E_com.Models.ShoppingCart
@{
    ViewData["Title"] = "Shopping Cart";
    decimal subTotal = Model.CartItems.Sum(ci => ci.Product!.DiscountedPrice * ci.Quantity);
}

<div class="container py-5">

    <div class="mb-4">
        <span class="section-label">Your Selection</span>
        <h1 class="section-title">Shopping Cart</h1>
    </div>

    @if (!Model.CartItems.Any())
    {
        <div class="empty-state">
            <i class="fa-solid fa-basket-shopping d-block"></i>
            <h4>Your Cart is Empty</h4>
            <p class="mb-4">You haven't added any items yet.</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary px-5">
                Browse Collection
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">

            <!-- Items -->
            <div class="col-lg-8">
                <div class="card border-0" style="box-shadow:var(--shadow-sm);">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0" style="font-size:.9rem;">
                            <thead>
                                <tr style="border-bottom:2px solid var(--clr-border);">
                                    <th class="ps-4 py-3 fw-600" style="font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--clr-muted);font-weight:600;">Product</th>
                                    <th class="py-3 fw-600" style="font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--clr-muted);font-weight:600;">Qty</th>
                                    <th class="py-3 fw-600" style="font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--clr-muted);font-weight:600;">Total</th>
                                    <th class="pe-4 py-3"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CartItems)
                                {
                                    var img = item.Product?.ProductImages?.FirstOrDefault(pi => pi.IsPrimary)
                                           ?? item.Product?.ProductImages?.FirstOrDefault();
                                    <tr style="border-bottom:1px solid #f4f2ef;">
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@(img != null ? img.ImagePath : "/images/placeholder-product.png")"
                                                     style="width:64px;height:64px;object-fit:cover;border-radius:var(--radius-sm);border:1px solid var(--clr-border);"
                                                     alt="@item.Product?.Name"
                                                     onerror="this.src='https://placehold.co/100x100?text=P'" />
                                                <div>
                                                    <a asp-controller="Shop" asp-action="Details" asp-route-id="@item.ProductId"
                                                       style="font-weight:600;color:var(--clr-black);text-decoration:none;font-size:.9rem;">
                                                        @item.Product?.Name
                                                    </a>
                                                    <p class="mb-0" style="font-size:.75rem;color:var(--clr-muted);">@item.Product?.Brand</p>
                                                    <p class="mb-0 mt-1" style="font-size:.85rem;color:var(--clr-dark);font-weight:600;">
                                                        $@item.Product?.DiscountedPrice.ToString("F2")
                                                        @if (item.Product?.Discount > 0)
                                                        {
                                                            <span style="font-size:.75rem;color:var(--clr-muted);font-weight:400;text-decoration:line-through;margin-left:4px;">$@item.Product.Price.ToString("F2")</span>
                                                        }
                                                    </p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-3">
                                            <form asp-action="UpdateQuantity" method="post">
                                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                                <input type="number" name="quantity" class="form-control form-control-sm text-center"
                                                       value="@item.Quantity" min="1" max="@item.Product?.StockQuantity"
                                                       onchange="this.form.submit()"
                                                       style="width:70px;font-size:.9rem;" />
                                            </form>
                                        </td>
                                        <td class="py-3">
                                            <span style="font-weight:700;color:var(--clr-black);">
                                                $@((item.Product!.DiscountedPrice * item.Quantity).ToString("F2"))
                                            </span>
                                        </td>
                                        <td class="pe-4 py-3 text-end">
                                            <form asp-action="RemoveFromCart" method="post">
                                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-light" title="Remove"
                                                        style="border-radius:50%;width:34px;height:34px;padding:0;display:inline-flex;align-items:center;justify-content:center;">
                                                    <i class="fa fa-trash" style="font-size:.75rem;color:var(--clr-danger);"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="p-4 d-flex justify-content-between align-items-center" style="border-top:1px solid var(--clr-border);">
                        <a asp-controller="Shop" asp-action="Index" class="btn btn-light" style="font-size:.8rem;">
                            <i class="fa fa-arrow-left me-2"></i>Continue Shopping
                        </a>
                    </div>
                </div>
            </div>

            <!-- Summary -->
            <div class="col-lg-4">
                <div class="card border-0 p-4" style="box-shadow:var(--shadow-sm);position:sticky;top:86px;">
                    <h6 style="font-size:.72rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--clr-muted);margin-bottom:1.5rem;">Order Summary</h6>

                    <div class="d-flex justify-content-between mb-3" style="font-size:.9rem;">
                        <span style="color:var(--clr-muted);">Subtotal</span>
                        <span style="font-weight:600;">$@subTotal.ToString("F2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3" style="font-size:.9rem;">
                        <span style="color:var(--clr-muted);">Shipping</span>
                        <span style="color:#2d8a4e;font-weight:600;">Free</span>
                    </div>

                    <hr style="border-color:var(--clr-border);margin:1.25rem 0;" />

                    <div class="d-flex justify-content-between mb-4">
                        <span style="font-weight:700;font-size:1rem;">Total</span>
                        <span style="font-weight:700;font-size:1.3rem;color:var(--clr-black);">$@subTotal.ToString("F2")</span>
                    </div>

                    <a asp-controller="Checkout" asp-action="Index" class="btn btn-primary w-100 py-2 mb-2">
                        <i class="fa fa-credit-card me-2"></i>Proceed to Checkout
                    </a>
                </div>
            </div>

        </div>
    }
</div>
