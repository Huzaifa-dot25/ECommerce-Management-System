@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-6 text-center">
        <div class="card shadow-lg border-0 rounded-4 p-5 my-5">
            <div class="mb-4">
                <i class="fa fa-envelope-open-text fa-4x text-primary animate__animated animate__bounceIn"></i>
            </div>
            <h2 class="fw-bold mb-3">Check Your Email</h2>
            <p class="text-muted mb-4 fs-5">
                We've sent password reset instructions to your email address (logged in system console).
            </p>

            @if (TempData["ResetLink"] != null)
            {
                <div class="alert alert-info border-0 rounded-3 text-start mb-4 shadow-sm">
                    <h5 class="alert-heading fw-bold"><i class="fa fa-info-circle me-1"></i> Demonstration Link</h5>
                    <p class="mb-2">For testing purposes, click the link below to reset the password:</p>
                    <a href="@TempData["ResetLink"]" class="text-break fw-semibold">@TempData["ResetLink"]</a>
                </div>
            }

            <div>
                <a asp-action="Login" class="btn btn-primary px-4 py-2.5 rounded-3 fw-bold bg-gradient">Back to Login</a>
            </div>
        </div>
    </div>
</div>
