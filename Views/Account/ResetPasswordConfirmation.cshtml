@{
    ViewData["Title"] = "Reset Password Confirmation";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-6 text-center">
        <div class="card shadow-lg border-0 rounded-4 p-5 my-5">
            <div class="mb-4">
                <i class="fa fa-check-circle fa-4x text-success animate__animated animate__bounceIn"></i>
            </div>
            <h2 class="fw-bold mb-3">Reset Completed</h2>
            <p class="text-muted mb-4 fs-5">
                Your password has been successfully reset.
            </p>
            <div>
                <a asp-action="Login" class="btn btn-primary px-4 py-2.5 rounded-3 fw-bold bg-gradient">Back to Login</a>
            </div>
        </div>
    </div>
</div>
