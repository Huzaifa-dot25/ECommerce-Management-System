@model E_com.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden my-5">
            <div class="card-header bg-gradient bg-primary text-white text-center py-4 border-0">
                <h3 class="mb-0 fw-bold">Welcome Back</h3>
                <p class="mb-0 opacity-75">Sign in to your account</p>
            </div>
            <div class="card-body p-5">
                <form asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa fa-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control border-start-0 bg-light" placeholder="name@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <a asp-action="ForgotPassword" class="small text-primary text-decoration-none">Forgot Password?</a>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa fa-lock text-muted"></i></span>
                            <input asp-for="Password" type="password" class="form-control border-start-0 bg-light" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label text-muted"></label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2.5 rounded-3 fw-bold bg-gradient shadow-sm">Login</button>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3 border-0">
                <span class="text-muted">Don't have an account?</span>
                <a asp-action="Register" class="text-primary fw-bold text-decoration-none ms-1">Register here</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
