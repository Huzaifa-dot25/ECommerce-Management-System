@model E_com.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="row justify-content-center align-items-center min-vh-75 py-5">
    <div class="col-md-5 col-lg-4">

        <div class="text-center mb-4">
            <span class="section-label">Welcome Back</span>
            <h2 class="section-title">Sign In</h2>
        </div>

        <div class="card border-0 p-4 p-md-5" style="box-shadow:var(--shadow-md);">
            <form asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded mb-3 py-2" style="font-size:.85rem;"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="fa fa-envelope" style="font-size:.8rem;"></i></span>
                        <input asp-for="Email" class="form-control border-start-0" placeholder="you@example.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger" style="font-size:.78rem;"></span>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Password" class="form-label mb-0">Password</label>
                        <a asp-action="ForgotPassword" style="font-size:.75rem;color:var(--clr-muted);text-decoration:none;">Forgot password?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="fa fa-lock" style="font-size:.8rem;"></i></span>
                        <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger" style="font-size:.78rem;"></span>
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label" style="font-size:.83rem;color:var(--clr-mid);"></label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">Sign In</button>
            </form>
        </div>

        <p class="text-center mt-3 mb-0" style="font-size:.84rem;color:var(--clr-muted);">
            Don't have an account?
            <a asp-action="Register" style="font-weight:600;color:var(--clr-black);text-decoration:none;">Create one &rarr;</a>
        </p>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
