@model E_com.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="container py-5">
    <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
                <div class="card-body text-center bg-light py-4">
                    <h5 class="fw-bold mb-1">@User.Identity?.Name</h5>
                    <p class="text-muted small mb-0">Security Settings</p>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Profile" class="list-group-item list-group-item-action fw-semibold"><i class="fa fa-user-circle me-2"></i> Account Details</a>
                    <a asp-action="ChangePassword" class="list-group-item list-group-item-action active fw-semibold"><i class="fa fa-key me-2"></i> Change Password</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Dashboard" class="list-group-item list-group-item-action text-danger fw-semibold"><i class="fa fa-dashboard me-2"></i> Admin Panel</a>
                    }
                    else
                    {
                        <a asp-controller="Orders" asp-action="MyOrders" class="list-group-item list-group-item-action fw-semibold"><i class="fa fa-shopping-bag me-2"></i> My Orders</a>
                        <a asp-controller="Wishlist" asp-action="Index" class="list-group-item list-group-item-action fw-semibold"><i class="fa fa-heart me-2"></i> Wishlist</a>
                    }
                </div>
            </div>
        </div>

        <!-- Main Edit Form -->
        <div class="col-md-9">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-0">
                    <h4 class="mb-0 fw-bold text-dark"><i class="fa fa-lock text-primary me-2"></i>Update Password</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="OldPassword" class="form-label fw-semibold"></label>
                            <input asp-for="OldPassword" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="OldPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div>
                            <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold"><i class="fa fa-key me-1"></i> Update Password</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
